# Локальная изоляция компаний (KelyanMedia / WhiteWay / Enter Group Media) — три отдельные SQLite-файлы.
# Без права CREATE DATABASE в PostgreSQL это проще, чем отдельные PG-базы.
DATABASE_URL=sqlite:///./data_kelyanmedia.db
DATABASE_SEPARATE_DBS=true
SECRET_KEY=change_me

# Альтернатива: PostgreSQL — одна база на компанию (нужны CREATE DATABASE или отдельные URL):
# DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/enterdebt
# DATABASE_SEPARATE_DBS=true
# затем создать enterdebt_whiteway и enterdebt_enter_group_media (см. scripts/create_postgres_company_databases.sql)
# либо задать DATABASE_URL_WHITEWAY / DATABASE_URL_ENTER_GROUP_MEDIA
