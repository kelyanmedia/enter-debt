{
  "name": "enterdebt-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true ./node_modules/node/bin/node ./node_modules/next/dist/bin/next dev -p 3000 -H 0.0.0.0",
    "dev:clean": "rm -rf .next node_modules/.cache && WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true ./node_modules/node/bin/node ./node_modules/next/dist/bin/next dev -p 3000 -H 0.0.0.0",
    "build": "./node_modules/node/bin/node ./node_modules/next/dist/bin/next build",
    "start": "./node_modules/node/bin/node ./node_modules/next/dist/bin/next start -p 3000 -H 0.0.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "node": "^20.20.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
