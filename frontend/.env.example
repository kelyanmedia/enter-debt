# Скопируй в .env.local. Порт должен совпадать с uvicorn (по умолчанию 8000).
# Если API на другом порту — например: BACKEND_URL=http://127.0.0.1:8001
# Не добавляйте /api в конец — иначе запросы пойдут на .../api/api/... и вход даст 404 Not Found.
BACKEND_URL=http://127.0.0.1:8000

# Опционально для фронта: прямой URL API, если nginx режет только часть /api (CEO layout, ручные строки P&L).
# NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
