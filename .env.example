# Database (external PostgreSQL, e.g. FastPanel managed)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname

# Backend
SECRET_KEY=change_this_to_random_string_in_production
ADMIN_EMAIL=admin@entergroup.uz
ADMIN_PASSWORD=admin123

# Telegram Bot (токен из @BotFather — только в .env на сервере, не в git)
BOT_TOKEN=your_bot_token_here
# Должен совпадать с привязкой админа в БД (по умолчанию 1333127107)
ADMIN_TELEGRAM_CHAT_ID=1333127107
# Пароль, который пользователь вводит в боте после /start (до модерации)
BOT_ACCESS_PASSWORD=EnterDebt2026
# Одинаковый секрет в backend и в процессе бота (заголовок X-Internal-Secret)
INTERNAL_API_SECRET=generate_a_long_random_string
# Публичный URL панели (для сообщения менеджеру после одобрения)
APP_PUBLIC_URL=https://debt.agasiarakelyan.com
# URL API для бота (локально: http://127.0.0.1:8000)
API_URL=http://127.0.0.1:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used by Next.js server-side rewrites in Docker (set automatically in docker-compose)
# BACKEND_URL=http://127.0.0.1:8000
