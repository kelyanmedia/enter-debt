# Database (external PostgreSQL, e.g. FastPanel managed)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname

# Backend
SECRET_KEY=change_this_to_random_string_in_production
ADMIN_EMAIL=admin@entergroup.uz
ADMIN_PASSWORD=admin123

# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used by Next.js server-side rewrites in Docker (set automatically in docker-compose)
# BACKEND_URL=http://127.0.0.1:8000
