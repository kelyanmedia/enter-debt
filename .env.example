# Database (external PostgreSQL, e.g. FastPanel managed)
#
# ВАЖНО: если в панели три компании (KelyanMedia / WhiteWay / Enter Group Media), а DATABASE_SEPARATE_DBS
# не включён — все три ходят в ОДНУ базу из DATABASE_URL (данные общие). Для изоляции на проде:
#
#   1) Под суперпользователем PostgreSQL:
#      CREATE DATABASE enterdebt_whiteway;
#      CREATE DATABASE enterdebt_enter_group_media;
#      GRANT ALL ON DATABASE enterdebt_whiteway TO ваш_пользователь;
#      GRANT ALL ON DATABASE enterdebt_enter_group_media TO ваш_пользователь;
#   2) В .env:
#      DATABASE_SEPARATE_DBS=true
#
# Либо задайте полные URL (без подмены имён БД):
# DATABASE_URL_WHITEWAY=postgresql://user:password@host:5432/enterdebt_whiteway
# DATABASE_URL_ENTER_GROUP_MEDIA=postgresql://user:password@host:5432/enterdebt_enter_group_media
#
# Одна база на всех (тест / простой Hetzner): оставьте DATABASE_SEPARATE_DBS=false или не задавайте.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/enterdebt
# DATABASE_SEPARATE_DBS=true
# DATABASE_URL_KELYANMEDIA=postgresql://user:password@127.0.0.1:5432/enterdebt
# DATABASE_URL_WHITEWAY=postgresql://user:password@127.0.0.1:5432/enterdebt_whiteway
# DATABASE_URL_ENTER_GROUP_MEDIA=postgresql://user:password@127.0.0.1:5432/enterdebt_enter_group_media

# Backend
SECRET_KEY=change_this_to_random_string_in_production
ADMIN_EMAIL=admin@entergroup.uz
ADMIN_PASSWORD=admin123

# Telegram Bot (токен из @BotFather — только в .env на сервере, не в git)
BOT_TOKEN=your_bot_token_here
# Должен совпадать с привязкой админа в БД (по умолчанию 1333127107)
ADMIN_TELEGRAM_CHAT_ID=1333127107
# Пароль, который пользователь вводит в боте после /start (до модерации)
BOT_ACCESS_PASSWORD=EnterDebt2026
# Секрет бот→API (X-Internal-Secret). Если не задан — backend и бот используют один и тот же встроенный дефолт.
# Для продакшена лучше задать свою длинную строку одинаково для backend и bot.
# INTERNAL_API_SECRET=
# Публичный URL панели (для сообщения менеджеру после одобрения)
APP_PUBLIC_URL=https://debt.agasiarakelyan.com
# URL API для бота (локально: http://127.0.0.1:8000)
API_URL=http://127.0.0.1:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used by Next.js server-side rewrites in Docker (set automatically in docker-compose)
# BACKEND_URL=http://127.0.0.1:8000
